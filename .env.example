# Logos Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Groq API (https://console.groq.com)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Database
DB_PATH=./server/db/logos.db

# ── Features Enabled by API Key ──────────────────────────────
# With GROQ_API_KEY:
#   ✅ Real image → prompt (Vision)
#   ✅ Real audio → prompt (Whisper + LLM)
#   ✅ Real video → prompt (Frame extraction + Vision)
#   ✅ Real URL → prompt (LLM analysis)
#   ✅ Real code → prompt (LLM analysis)
#   ✅ Real prompt → website (LLM code generation)
#
# Without GROQ_API_KEY:
#   ⚠️ Template mode — structured templates instead of AI

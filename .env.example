# ═══════════════════════════════════════════════════════════════
# LOGOS — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Groq API (required for AI features) ──
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (required for auth + cloud sync) ──
# Create project at: https://supabase.com
# Find values in: Settings → API
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Analytics ──
# VITE_POSTHOG_KEY=phc_xxxxxxxx
# VITE_POSTHOG_HOST=https://app.posthog.com
